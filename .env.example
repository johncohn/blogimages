# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# WordPress site base URL (no trailing slash)
WP_BASE=http://johncohn.org/base

# Your WordPress username
WP_USER=your_username

# Application Password from WP Admin → Users → Your Profile → Application Passwords
# It will look like: xxxx xxxx xxxx xxxx xxxx xxxx  (spaces are fine, or remove them)
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
